{
  "name": "xcom-enhanced-gallery",
  "version": "2.1.2",
  "description": "Media viewer and download functionality for X.com",
  "type": "module",
  "private": true,
  "scripts": {
    "prebuild": "pnpm -s quality",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "build:fast": "vite build",
    "check:src": "tsc --noEmit",
    "check": "pnpm check:src",
    "typecheck": "pnpm -s check",
    "knip": "knip --dependencies",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "fmt": "biome check --linter-enabled=false .",
    "fmt:fix": "biome check --write --linter-enabled=false .",
    "fmt:check": "pnpm -s fmt",
    "circular": "pnpm dlx madge --circular --ts-config tsconfig.json --extensions ts,tsx src",
    "quality": "pnpm -s fmt && pnpm -s lint && pnpm -s check && pnpm -s circular && pnpm -s knip",
    "quality:ci": "pnpm -s quality",
    "quality:fix": "pnpm -s fmt:fix && pnpm -s lint:fix && pnpm -s check && pnpm -s circular && pnpm -s knip"
  },
  "keywords": [
    "userscript",
    "x.com",
    "twitter",
    "gallery",
    "media"
  ],
  "author": "PiesP",
  "license": "MIT",
  "engines": {
    "node": ">=26.0.0",
    "pnpm": ">=11.2.2"
  },
  "packageManager": "pnpm@11.2.2",
  "volta": {
    "node": "26.3.0",
    "pnpm": "11.2.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/PiesP/xcom-enhanced-gallery"
  },
  "bugs": {
    "url": "https://github.com/PiesP/xcom-enhanced-gallery/issues"
  },
  "homepage": "https://github.com/PiesP/xcom-enhanced-gallery#readme",
  "engines": {
    "node": ">=26.0.0",
    "pnpm": ">=11.2.2"
  },
  "packageManager": "pnpm@11.2.2",
  "volta": {
    "node": "26.3.0",
    "pnpm": "11.2.2"
  },
  "dependencies": {
    "solid-js": "^1.9.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^25.9.1",
    "knip": "^6.15.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-solid": "^2.11.12"
  }
}
