{
  "name": "xcom-enhanced-gallery",
  "version": "1.9.3",
  "description": "Media viewer and download functionality for X.com",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "pnpm quality:fix && vite build",
    "build:dev": "vite build --mode development",
    "check:src": "tsc --noEmit --project tsconfig.build.json",
    "check:tools": "tsc --noEmit --project tsconfig.tools.json",
    "check": "pnpm check:src && pnpm check:tools",
    "typecheck": "pnpm -s check",
    "check:tsdoc": "node ./tooling/node/check-tsdoc.ts",
    "knip": "knip --no-config-hints",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "fmt": "biome check --linter-enabled=false .",
    "fmt:fix": "biome check --write --linter-enabled=false .",
    "fmt:check": "pnpm -s fmt",
    "circular": "pnpm dlx madge --circular --ts-config tsconfig.json --extensions ts,tsx src",
    "preinstall": "node ./tooling/node/ensure-pnpm.ts",
    "quality": "pnpm -s fmt && pnpm -s lint && pnpm -s check && pnpm -s circular && pnpm -s check:tsdoc && pnpm -s knip",
    "quality:fix": "pnpm -s fmt:fix && pnpm -s lint:fix && pnpm -s check && pnpm -s circular && pnpm -s check:tsdoc && pnpm -s knip",
    "test:deps:check": "pnpm -C test run deps:check",
    "test:deps:sync": "pnpm -C test run deps:sync",
    "test:install": "pnpm -C test install",
    "test:unit": "pnpm -C test run test",
    "test:e2e": "pnpm -C test run e2e",
    "test:mut:priority": "pnpm -C test run mut:priority",
    "test:all": "pnpm -C test run test:all",
    "verify": "pnpm build && pnpm run test:all"
  },
  "keywords": [
    "userscript",
    "x.com",
    "twitter",
    "gallery",
    "media"
  ],
  "author": "PiesP",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PiesP/xcom-enhanced-gallery"
  },
  "bugs": {
    "url": "https://github.com/PiesP/xcom-enhanced-gallery/issues"
  },
  "homepage": "https://github.com/PiesP/xcom-enhanced-gallery#readme",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.29.2"
  },
  "packageManager": "pnpm@10.29.2",
  "volta": {
    "node": "24.15.0",
    "pnpm": "10.29.2"
  },
  "dependencies": {
    "solid-js": "^1.9.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@microsoft/tsdoc": "^0.16.0",
    "@types/node": "^25.6.2",
    "knip": "^6.12.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vite-plugin-solid": "^2.11.12"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "rollup": "4.59.0",
      "minimatch": "10.2.3",
      "semver": "7.7.3"
    },
    "peerDependencyRules": {
      "ignoreMissing": [
        "vite"
      ],
      "allowAny": [
        "vite"
      ]
    }
  }
}
