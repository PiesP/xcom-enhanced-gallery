{
  "name": "xcom-enhanced-gallery",
  "version": "2.1.2",
  "description": "Media viewer and download functionality for X.com",
  "type": "module",
  "private": true,
  "scripts": {
    "prebuild": "pnpm -s quality",
    "build": "vite build",
    "build:extension": "vite build --config vite.extension.config.ts && vite build --config vite.extension.cs.config.ts && npx tsx scripts/verify-extension-build.ts",
    "build:extension:firefox": "vite build --config vite.extension.firefox.config.ts && npx tsx scripts/verify-extension-build.ts",
    "build:all": "pnpm build && pnpm build:extension && pnpm build:extension:firefox",
    "build:dev": "vite build --mode development",
    "build:fast": "vite build",
    "package:extension": "npx tsx scripts/package-extension.ts",
    "package:all": "pnpm build:all && pnpm package:extension",
    "clean": "rimraf dist dist-extension dist-extension-firefox",
    "mut": "cd test && npx stryker run ../stryker.conf.json --reporters=progress",
    "mut:fast": "cd test && npx stryker run ../stryker.conf.json --reporters=progress --mutators=boolean,arithmetic,conditional-boundary,equality-operator,negate-conditional,string",
    "check:src": "tsc --noEmit",
    "check": "pnpm check:src",
    "typecheck": "pnpm -s check",
    "knip": "knip --dependencies",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "fmt": "biome check --linter-enabled=false .",
    "fmt:fix": "biome check --write --linter-enabled=false .",
    "fmt:check": "pnpm -s fmt",
    "circular": "pnpm dlx madge --circular --ts-config tsconfig.json --extensions ts,tsx src",
    "quality": "pnpm -s fmt && pnpm -s lint && pnpm -s check && pnpm -s circular && pnpm -s knip",
    "quality:ci": "pnpm -s quality",
    "quality:fix": "pnpm -s fmt:fix && pnpm -s lint:fix && pnpm -s check && pnpm -s circular && pnpm -s knip",
    "verify": "pnpm -s quality && pnpm -s build",
    "test": "cd test && pnpm test",
    "test:watch": "cd test && pnpm test:watch",
    "test:cov": "cd test && pnpm test:cov",
    "test:e2e": "cd test && pnpm e2e",
    "test:e2e:headed": "cd test && pnpm e2e:headed",
    "test:setup": "cd test && pnpm install"
  },
  "keywords": [
    "userscript",
    "x.com",
    "twitter",
    "gallery",
    "media"
  ],
  "author": "PiesP",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.2.2"
  },
  "packageManager": "pnpm@11.2.2",
  "volta": {
    "node": "26.4.0",
    "pnpm": "11.2.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/PiesP/xcom-enhanced-gallery"
  },
  "bugs": {
    "url": "https://github.com/PiesP/xcom-enhanced-gallery/issues"
  },
  "homepage": "https://github.com/PiesP/xcom-enhanced-gallery#readme",
  "dependencies": {
    "solid-js": "^1.9.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/node": "^26.1.0",
    "knip": "^6.24.0",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vite-plugin-solid": "^2.11.12"
  }
}
