{
  "name": "xcom-enhanced-gallery",
  "version": "0.2.5",
  "description": "Media viewer and download functionality for X.com",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite --mode development",
    "build": "vite build --mode production",
    "build:dev": "vite build --mode development",
    "build:purged": "cross-env BUILD_WITH_PURGECSS=1 vite build --mode production",
    "build:verified": "vite build --mode production && node ./scripts/verify-bundle.mjs",
    "build:all": "npm run build:dev && npm run build:verified",
    "clean": "rimraf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "test:fast": "cross-env VITEST_MODE=fast vitest run --exclude='**/refactoring/**' --exclude='**/integration/**'",
    "test:debug": "cross-env VITEST_MODE=debug vitest run --reporter=verbose",
    "test:debug:watch": "cross-env VITEST_MODE=debug vitest --reporter=verbose",
    "test:refactoring": "cross-env VITEST_MODE=refactoring VITEST_DISABLE_COVERAGE=1 vitest run test/refactoring",
    "test:refactoring:serial": "cross-env VITEST_MODE=refactoring node ./scripts/run-refactoring-serial.mjs",
    "test:ci": "cross-env VITEST_MODE=ci NODE_ENV=test vitest run --coverage --reporter=verbose",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test:fast",
    "check:fix": "npm run typecheck && npm run lint:fix && npm run format && npm run test:fast",
    "check:coverage": "npm run typecheck && npm run lint && npm run format:check && npm run test:coverage",
    "lint": "eslint ./src --report-unused-disable-directives --max-warnings 0 && npm run stylelint",
    "lint:fix": "eslint ./src --report-unused-disable-directives --max-warnings 0 --fix && npm run stylelint:fix",
    "stylelint": "stylelint \"src/**/*.{css,scss}\"",
    "stylelint:fix": "stylelint \"src/**/*.{css,scss}\" --fix",
    "lint:staged": "lint-staged",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify:bundle": "node ./scripts/verify-bundle.mjs",
    "quality": "npm run check:coverage",
    "validate": "npm run typecheck && npm run lint:fix && npm run format",
    "prebuild": "npm run check:fix",
    "deps:check": "dependency-cruiser src --validate --config .dependency-cruiser.cjs",
    "deps:graph": "dependency-cruiser --config .dependency-cruiser.cjs --output-type dot src | dot -T svg > docs/dependency-graph.svg || dependency-cruiser --config .dependency-cruiser.cjs --output-type dot src | sfdp -T svg > docs/dependency-graph.svg",
    "deps:graph:dot": "dependency-cruiser --config .dependency-cruiser.cjs --output-type dot src > docs/dependency-graph.dot",
    "deps:json": "dependency-cruiser --config .dependency-cruiser.cjs --output-type json --output-to docs/dependency-graph.json src",
    "deps:all": "npm run deps:json && npm run deps:graph:dot && npm run deps:graph && npm run deps:check",
    "prepare": "husky"
  },
  "dependencies": {
    "@preact/signals": "^2.2.1",
    "@preact/signals-core": "^1.11.0",
    "fflate": "^0.8.2",
    "preact": "^10.27.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "9.33.0",
    "@fullhuman/postcss-purgecss": "^7.0.2",
    "@preact/preset-vite": "^2.10.2",
    "@testing-library/jest-dom": "6.7.0",
    "@testing-library/preact": "3.2.4",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^24.2.1",
    "@types/tampermonkey": "^5.0.4",
    "@typescript-eslint/eslint-plugin": "^8.39.1",
    "@typescript-eslint/parser": "^8.39.1",
    "@vitest/coverage-istanbul": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.21",
    "cross-env": "^10.0.0",
    "cssnano": "7.1.0",
    "dependency-cruiser": "^17.0.1",
    "eslint": "9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.1.5",
    "lucide-preact": "^0.539.0",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "postcss-custom-properties": "^14.0.6",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "stylelint": "^16.23.1",
    "stylelint-config-recommended": "^17.0.0",
    "stylelint-config-standard": "^39.0.0",
    "stylelint-config-standard-scss": "^15.0.1",
    "stylelint-scss": "^6.12.1",
    "terser": "5.43.1",
    "ts-node": "^10.9.2",
    "typescript": "5.9.2",
    "vite": "7.1.2",
    "vitest": "^3.2.4",
    "vite-plugin-monkey": "^6.0.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.{js,jsx}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{css,scss}": [
      "stylelint --fix",
      "prettier --write"
    ]
  }
}
