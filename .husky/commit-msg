#!/usr/bin/env sh

# =============================================================================
# Commit Message Validation Hook for X.com Enhanced Gallery (Optimized)
# =============================================================================
# 한국어 커밋 메시지를 지원하는 Conventional Commits 표준 검증 (최적화)
# HUSKY_SKIP=1 환경변수로 검증을 건너뛸 수 있습니다.
# =============================================================================

START_TIME=$(date +%s)

# 스킵 옵션 확인 (빠른 종료)
if [ "$HUSKY_SKIP" = "1" ]; then
  echo "⏭️  커밋 메시지 검증 건너뛰기 (HUSKY_SKIP=1)"
  exit 0
fi

echo "📝 커밋 메시지 검증 중..."

# 커밋 메시지 미리 읽기로 빠른 검증
COMMIT_MSG=$(head -n 1 "$1" 2>/dev/null)
MSG_LENGTH=${#COMMIT_MSG}

# 빈 메시지 빠른 체크
if [ "$MSG_LENGTH" -eq 0 ]; then
  echo "❌ 커밋 메시지가 비어있습니다"
  exit 1
fi

# 길이 제한 빠른 체크 (너무 길거나 짧은 메시지)
if [ "$MSG_LENGTH" -gt 100 ]; then
  echo "⚠️  커밋 메시지가 깁니다 ($MSG_LENGTH 자). 간결하게 작성하는 것을 권장합니다."
elif [ "$MSG_LENGTH" -lt 10 ]; then
  echo "⚠️  커밋 메시지가 짧습니다 ($MSG_LENGTH 자). 더 설명적으로 작성하는 것을 권장합니다."
fi

# 개발 브랜치에서는 더 관대한 검증
BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")
echo "🌿 브랜치: $BRANCH"

case "$BRANCH" in
  dev*|feature*|experiment*|refactor*|hotfix*|wip*)
    echo "🔧 개발 브랜치 감지: 관대한 검증 모드"
    
    # 기본 패턴 빠른 체크 (conventional commits 여부)
    if echo "$COMMIT_MSG" | grep -qE '^(feat|fix|docs|style|refactor|test|chore|perf|ci|build|revert)(\(.+\))?: '; then
      echo "✅ Conventional Commits 형식 감지"
    else
      echo "⚠️  비표준 커밋 메시지 형식 (개발 브랜치이므로 허용)"
      echo "💡 권장 형식: type(scope): 설명"
    fi
    
    # 개발 브랜치에서는 commitlint를 경고 모드로 실행
    if ! npx --no -- commitlint --edit "$1" --config commitlint.config.cjs 2>/dev/null; then
      echo "⚠️  커밋 메시지가 표준 형식과 다릅니다 (개발 브랜치이므로 허용)"
      echo "💡 main/master 브랜치 병합 전에는 표준 형식으로 수정해주세요."
    fi
    ;;
  *)
    # 메인 브랜치에서는 엄격한 검증
    echo "🏛️  메인 브랜치: 엄격한 검증 모드"
    
    # 더 빠른 패턴 매칭으로 사전 검증
    if ! echo "$COMMIT_MSG" | grep -qE '^(feat|fix|docs|style|refactor|test|chore|perf|ci|build|revert)(\(.+\))?: .+'; then
      echo "❌ 잘못된 커밋 메시지 형식"
      echo "📋 올바른 형식: type(scope): 설명"
      echo "💡 예시: feat(toolbar): 새로고침 버튼 추가"
      exit 1
    fi
    
    # commitlint로 세부 검증
    if ! npx --no -- commitlint --edit "$1" --config commitlint.config.cjs; then
      echo ""
      echo "❌ 커밋 메시지 검증 실패"
      echo ""
      echo "💡 올바른 형식: type(scope): 설명"
      echo "   또는 HUSKY_SKIP=1 git commit 으로 건너뛰기 가능"
      echo ""
      echo "   📋 사용 가능한 타입:"
      echo "   • feat      - 새로운 기능 추가"
      echo "   • fix       - 버그 수정"
      echo "   • docs      - 문서 변경"
      echo "   • refactor  - 리팩토링"
      echo "   • test      - 테스트 추가/수정"
      echo "   • chore     - 기타 변경사항"
      echo ""
      exit 1
    fi
    ;;
esac

ELAPSED_TIME=$(($(date +%s) - $START_TIME))
echo "✅ 커밋 메시지 검증 통과! (⏱️  ${ELAPSED_TIME}초)"
