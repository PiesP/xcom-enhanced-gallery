#!/usr/bin/env bash
set -euo pipefail

branch="$(git symbolic-ref --quiet --short HEAD || true)"
git_dir="$(git rev-parse --git-dir)"

is_default_branch() {
  [[ "$1" == "master" || "$1" == "main" ]]
}

if [[ -z "$branch" ]]; then
  echo "Commits from a detached HEAD are blocked. Create a work branch first." >&2
  exit 1
fi

# Completing a merge on the default branch is allowed; ordinary commits are not.
if is_default_branch "$branch" && [[ -f "$git_dir/MERGE_HEAD" ]]; then
  exit 0
fi

if is_default_branch "$branch"; then
  echo "Direct commits on '$branch' are blocked. Use a work branch and a pull request." >&2
  exit 1
fi
