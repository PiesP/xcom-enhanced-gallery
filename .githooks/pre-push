#!/usr/bin/env bash
set -euo pipefail

zero="0000000000000000000000000000000000000000"

while read -r local_ref local_sha remote_ref remote_sha; do
  case "$remote_ref" in
    refs/heads/master|refs/heads/main) ;;
    *) continue ;;
  esac

  if [[ "$local_sha" == "$zero" ]]; then
    echo "Deleting the default branch is blocked." >&2
    exit 1
  fi

  parents="$(git rev-list --parents -n 1 "$local_sha")"
  read -r _commit first_parent second_parent extra <<< "$parents"
  if [[ -z "$first_parent" || -z "$second_parent" || -n "$extra" ]]; then
    echo "Default-branch pushes must use a two-parent --no-ff merge commit." >&2
    exit 1
  fi

  if [[ "$remote_sha" != "$zero" && "$first_parent" != "$remote_sha" ]]; then
    echo "The --no-ff merge must be based on the current remote default branch." >&2
    exit 1
  fi
done
