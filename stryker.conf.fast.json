{
  "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker/master/packages/core/schema/stryker-schema.json",
  "mutate": [
    "src/utils/**/*.ts",
    "src/shared/async/**/*.ts",
    "src/shared/core/**/*.ts",
    "src/features/gallery/hooks/use-gallery-download.ts",
    "src/services/download/**/*.ts",
    "!src/**/*.d.ts",
    "!src/types/**",
    "!src/platform/**",
    "!src/**/types.ts"
  ],
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.config.ts",
    "related": false
  },
  "reporters": ["progress"],
  "coverageAnalysis": "all",
  "inPlace": true,
  "concurrency": 2,
  "timeoutMS": 120000,
  "plugins": ["@stryker-mutator/vitest-runner"],
  "mutator": {
    "excludedMutations": [
      "StringLiteral",
      "ArrayDeclaration",
      "ObjectLiteral",
      "ArrowFunction",
      "BlockStatement",
      "ConditionalExpression",
      "Regex",
      "UnaryOperator",
      "UpdateOperator",
      "OptionalChaining",
      "AssignmentOperator",
      "PrefixDecrementOperator",
      "PrefixIncrementOperator",
      "PostfixDecrementOperator",
      "PostfixIncrementOperator",
      "MethodExpression",
      "NonNullAssertion",
      "CheckedStatement",
      "SwitchCase",
      "WhileStatement",
      "ForStatement",
      "EqualityOperator",
      "BooleanLiteral"
    ]
  }
}
