# pnpm Configuration for X.com Enhanced Gallery
# Node.js 24 + pnpm 10.x environment

# Enforce compatible Node/pnpm versions
engine-strict=true

# Lockfile format
lockfile-version=3

# Hoist patterns for development tools
public-hoist-pattern[]=*types*
public-hoist-pattern[]=*biome*

# Install behavior
prefer-frozen-lockfile=true
auto-install-peers=true
strict-peer-dependencies=false

# Performance
prefer-offline=true

# Allow installing security patches immediately for trusted build tools
# These packages release security fixes that need to be applied before the default 3-day age window
minimum-release-age-exclude[]=vite
